{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32F103ZE Debug (J-Link)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "servertype": "jlink",
            "serverpath": "C:/Program Files/SEGGER/JLink_V816/JLinkGDBServerCL.exe",
            "armToolchainPath": "D:/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin",
            "device": "STM32F103ZE",
            "interface": "swd",
            "runToEntryPoint": "main",
            "executable": "${workspaceFolder}/build/LEDtest.elf",
            "preLaunchTask": "Build firmware",
            "postRestartCommands": [
                "monitor reset"
            ]
        },
        {
            "name": "Attach STM32F103ZE (J-Link)",
            "type": "cortex-debug",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "servertype": "jlink",
            "serverpath": "C:/Program Files/SEGGER/JLink_V816/JLinkGDBServerCL.exe",
            "armToolchainPath": "D:/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin",
            "device": "STM32F103ZE",
            "interface": "swd",
            "executable": "${workspaceFolder}/build/LEDtest.elf"
        }
    ]
}
